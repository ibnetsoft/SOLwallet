# ===========================================
# SOLwallet — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Telegram Bot (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Supabase (required — create project at https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Solana RPC (required — get from Helius, QuickNode, or Triton)
SOLANA_RPC_URL=https://your-rpc-endpoint.com

# Manifest.trade DEX (required — get API key from https://manifest.trade)
MANIFEST_API_KEY=your_manifest_api_key

# Admin (required — set your own secret)
ADMIN_SECRET=your_admin_secret_here

# App Config
MINI_APP_URL=http://localhost:3001
ADMIN_APP_URL=http://localhost:3002
SERVER_PORT=3000
NODE_ENV=development
